{
  "rewrites": [
    {
      "source": "/api/auth/login",
      "destination": "https://prod.horebpay.com/horeb/api/users/login"
    },
    {
      "source": "/api/:match*",
      "destination": "https://prod.horebpay.com/horeb/api/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}